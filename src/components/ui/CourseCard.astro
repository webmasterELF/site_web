---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  title: string
  image: ImageMetadata
  alt?: string
  href?: string
  category?: string
}

const {
  title,
  image,
  alt = title,
  href = '#',
  category,
} = Astro.props
---

<a class="course-card" href={href}>
  <div class="course-card__visual">
    <Image
      src={image}
      alt={alt}
      loading="lazy"
      decoding="async"
      width={400}
      height={400}
      class={"course__img"}
    />
    <div class="course-card__overlay">
      {category && (
        <span class="course-card__category">{category}</span>
      )}
      <p class="course-card__title">{title}</p>
      <span class="course-card__cta">
        Découvrir
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .course-card {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    position: relative;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .course-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
  }

  /* --- Visual (image + overlay) --- */
  .course-card__visual {
    position: relative;
    aspect-ratio: 1/1;
    overflow: hidden;
  }

  .course-card__visual .course__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }

  .course-card:hover .course-card__visual img {
    transform: scale(1.06);
  }

  /* --- Gradient overlay always visible at bottom --- */
  .course-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient( to top,rgba(0, 0, 0, 0.78) 0%,rgba(0, 0, 0, 0.3) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-1) var(--space-4);
    gap: var(--space-2);
    transition: background var(--transition-fast);
  }

  .course-card:hover .course-card__overlay {
    background: linear-gradient(to top,rgba(0, 0, 0, 0.88) 0%,rgba(0, 0, 0, 0.45) 55%,transparent 100%);
  }

  /* --- Category badge --- */
  .course-card__category {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    display: inline-block;
    align-self: flex-start;
    background-color: #ffffff8f;
    backdrop-filter: blur(8px);
    color: var(--text-on-dominant);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full, 999px);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* --- Title --- */
  .course-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    text-wrap: pretty;
    color: #ffffff;
    margin: 0;
    line-height: 1.3;
  }

  /* --- CTA inline --- */
  .course-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .course-card:hover .course-card__cta {
    opacity: 1;
    transform: translateY(0);
  }
</style>
