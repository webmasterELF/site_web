---
const links = [
  { name: 'Nos formations', href: '/formations' },
  { name: 'FAQ', href: '/faq' },
  { name: 'Blog', href: '/blog' },
  { name: 'Financement', href: '/financement' },
]
---

<nav class="footer-nav" aria-label="Liens rapides">
  <p class="footer-nav__title">Liens rapides</p>
  <ul class="footer-nav__list">
    {links.map((link) => (
      <li>
        <a href={link.href} class="footer-nav__link">{link.name}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .footer-nav__title {
    font-weight: 600;
    color: var(--color-white);
    margin-bottom: var(--space-3);
  }

  .footer-nav__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-nav__link {
    color: var(--color-white);
    opacity: 0.8;
    text-decoration: none;
    font-size: var(--text-sm);
    transition: opacity var(--transition-base);
  }

  .footer-nav__link:hover {
    opacity: 1;
  }
</style>
